# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MASTER_ADMIN_PASSWORD: Super-master password that can unlock every society.
# ADMIN_PASSWORD is still accepted for backward compatibility.
MASTER_ADMIN_PASSWORD="church-admin"

# SOCIETY_ADMIN_PASSWORDS: JSON map of society names to passwords.
# Example: {"GMCT":"gmct-password","St Pauls Baltemore":"st-pauls-password"}
SOCIETY_ADMIN_PASSWORDS='{"GMCT":"gmct-password","St Pauls Baltemore":"st-pauls-password"}'

# VITE_MASTER_ADMIN_PASSWORD and VITE_SOCIETY_ADMIN_PASSWORDS_JSON are used
# by the static GitHub Pages fallback when a backend auth server is not present.
VITE_MASTER_ADMIN_PASSWORD="church-admin"
VITE_SOCIETY_ADMIN_PASSWORDS_JSON='{"GMCT":"gmct-password","St Pauls Baltemore":"st-pauls-password"}'

# AUTH_SERVER_PORT: Optional port for the local auth server.
# Default is 8787.
AUTH_SERVER_PORT="8787"
